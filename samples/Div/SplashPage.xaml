<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    BackgroundColor="Red"
    Shell.FlyoutBehavior="Disabled"
    Shell.NavBarIsVisible="False"
    Title="SplashPage"
    x:Class="DivStart.SplashPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <ContentPage.Behaviors>
        <toolkit:StatusBarBehavior StatusBarColor="Blue" StatusBarStyle="{AppThemeBinding Default=LightContent, Light=DarkContent}" />
    </ContentPage.Behaviors>

    <Grid
        Padding="20"
        RowDefinitions="100,Auto,*"
        RowSpacing="20">
        <ActivityIndicator Color="Black" IsRunning="True" />

        <Image
            Grid.Row="1"
            HeightRequest="200"
            HorizontalOptions="Center"
            Source="divisibillfg.svg"
            WidthRequest="200" />

        <ScrollView Grid.Row="2" x:Name="sv">
            <Label
                LineBreakMode="WordWrap"
                VerticalOptions="Fill"
                x:Name="InfoBox" />
        </ScrollView>
    </Grid>
</ContentPage>